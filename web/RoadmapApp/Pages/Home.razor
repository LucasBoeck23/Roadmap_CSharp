@page "/"
@using RoadmapApp.Models
@using RoadmapApp.Services
@inject TopicService TopicService
@inject MarkdownService Markdown
@inject IJSRuntime JS

<div class="ide-layout">
    <!-- ACTIVITY BAR (ícones laterais tipo VS Code) -->
    <div class="activity-bar">
        @if (_tracks is not null)
        {
            @foreach (var track in _tracks)
            {
                <div class="activity-icon @(track.Id == _activeTrackId ? "activity-active" : "")"
                     title="@track.Nome"
                     @onclick="() => SwitchTrack(track)">
                    <img src="@track.Icone" alt="@track.Nome" />
                </div>
            }
        }
    </div>

    <!-- SIDEBAR (file explorer) -->
    <div class="sidebar">
        <div class="sidebar-header">EXPLORER</div>
        <div class="tree-view">
            @if (_activeTopics is not null)
            {
                <div class="tree-section">
                    <div class="tree-section-title">📂 @(_selectedTrack?.Nome ?? "")</div>
                    @foreach (var topic in _activeTopics)
                    {
                        <div class="tree-item @(IsTopicOpen(topic) ? "tree-selected" : "")"
                             @onclick="() => OpenTopic(topic)">
                            <span class="tree-icon">@GetFileIcon(topic)</span>
                            <span class="tree-label">@topic.Nome</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- MAIN EDITOR AREA -->
    <div class="editor-main">
        <!-- EDITOR TABS (sub-abas dos documentos abertos) -->
        @if (_openTabs.Count > 0)
        {
            <div class="editor-tabs">
                @foreach (var tab in _openTabs)
                {
                    <div class="editor-tab @(tab.Id == _activeTabId ? "editor-tab-active" : "")"
                         @onclick="() => ActivateTab(tab)">
                        <span class="editor-tab-icon">@GetFileIcon(tab)</span>
                        <span class="editor-tab-name">@tab.Nome</span>
                        <span class="editor-tab-close" @onclick="() => CloseTab(tab)" @onclick:stopPropagation="true">✕</span>
                    </div>
                }
            </div>
        }

        <!-- EDITOR CONTENT -->
        <div class="editor-content">
            @if (_activeTab is not null)
            {
                <div class="split-view">
                    <!-- PAINEL ESQUERDO: README -->
                    <div class="split-left">
                        <div class="split-header">
                            <span>README.md</span>
                        </div>
                        <div class="doc-view">
                            @if (_activeTabContent is not null && _viewingFile is null)
                            {
                                <div class="doc-readme markdown-body">
                                    @((MarkupString)Markdown.ToHtml(_readmeCache ?? ""))
                                </div>
                            }
                            else if (_readmeCache is not null)
                            {
                                <div class="doc-readme markdown-body">
                                    @((MarkupString)Markdown.ToHtml(_readmeCache))
                                </div>
                            }
                            else
                            {
                                <div class="empty-editor">
                                    <p class="empty-hint">// Sem README.md</p>
                                </div>
                            }

                            @if (_activeTab.Arquivos.Count > 0)
                            {
                                <div class="doc-tree">
                                    <div class="doc-tree-title">Estrutura do Projeto</div>
                                    <div class="doc-tree-content">
                                        @foreach (var file in _activeTab.Arquivos)
                                        {
                                            var fileName = file.Contains("/") ? file.Split('/').Last() : file;
                                            <div class="tree-line tree-file-link"
                                                 @onclick="() => OpenFileInRight(file)">
                                                @fileName
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- PAINEL DIREITO: Código -->
                    @if (_rightTabs.Count > 0)
                    {
                        <div class="split-resizer" id="split-resizer"></div>
                        <div class="split-right">
                            <div class="right-tabs">
                                @foreach (var rt in _rightTabs)
                                {
                                    var fileName = rt.Contains("/") ? rt.Split('/').Last() : rt;
                                    <div class="right-tab @(rt == _activeRightTab ? "right-tab-active" : "")"
                                         @onclick="() => ActivateRightTab(rt)">
                                        <span>@fileName</span>
                                        <span class="right-tab-close" @onclick="() => CloseRightTab(rt)" @onclick:stopPropagation="true">✕</span>
                                    </div>
                                }
                            </div>
                            <div class="right-content">
                                @if (_rightContent is not null)
                                {
                                    <div class="code-with-lines">
                                        <div class="line-numbers">
                                            @for (int i = 1; i <= _rightLineCount; i++)
                                            {
                                                <span>@i</span>
                                            }
                                        </div>
                                        <pre class="language-csharp code-text"><code class="language-csharp">@_rightContent</code></pre>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Welcome screen -->
                <div class="welcome">
                    <div class="welcome-title">Roadmap do Boeck</div>
                    <div class="welcome-sub">Selecione um tópico na sidebar para começar</div>
                </div>
            }
        </div>
    </div>

    <!-- STATUS BAR -->
    <div class="status-bar">
        <span class="status-item">📂 @(_activeTrackId ?? "—")</span>
        <span class="status-item">📊 @(_activeTopics?.Count ?? 0) tópicos</span>
        <span class="status-item">📑 @_openTabs.Count aberto(s)</span>
        <span class="status-item status-right">Roadmap do Boeck</span>
    </div>
</div>

@code {
    private Dictionary<string, List<Topic>>? _allTracks;
    private List<TrackInfo>? _tracks;
    private TrackInfo? _selectedTrack;
    private string? _activeTrackId;
    private List<Topic>? _activeTopics;

    // Tabs system
    private List<Topic> _openTabs = new();
    private string? _activeTabId;
    private Topic? _activeTab => _openTabs.FirstOrDefault(t => t.Id == _activeTabId);
    private string? _activeTabContent;
    private int _lineCount;
    private string? _viewingFile;

    // Right panel (code viewer)
    private List<string> _rightTabs = new();
    private string? _activeRightTab;
    private string? _rightContent;
    private int _rightLineCount;
    private string? _readmeCache;

    // Cache de conteúdo
    private Dictionary<string, string?> _contentCache = new();
    private bool _needsHighlight;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsHighlight)
        {
            _needsHighlight = false;
            await JS.InvokeVoidAsync("highlightCode");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _allTracks = await TopicService.GetAllTracksAsync();
        _tracks = await TopicService.GetTrackListAsync();
        if (_tracks.Count > 0)
        {
            _selectedTrack = _tracks[0];
            _activeTrackId = _tracks[0].Id;
            _activeTopics = await TopicService.GetTopicsByTrackAsync(_activeTrackId);
        }
    }

    private async Task SwitchTrack(TrackInfo track)
    {
        _selectedTrack = track;
        _activeTrackId = track.Id;
        _activeTopics = await TopicService.GetTopicsByTrackAsync(track.Id);
    }

    private async Task OpenTopic(Topic topic)
    {
        if (!_openTabs.Any(t => t.Id == topic.Id && t.Pasta == topic.Pasta))
        {
            _openTabs.Add(topic);
        }

        _activeTabId = topic.Id;
        _viewingFile = null;
        _rightTabs.Clear();
        _activeRightTab = null;
        _rightContent = null;
        await LoadContent(topic);
        _readmeCache = _activeTabContent;
    }

    private async Task ActivateTab(Topic tab)
    {
        _activeTabId = tab.Id;
        _viewingFile = null;
        await LoadContent(tab);
    }

    private void CloseTab(Topic tab)
    {
        _openTabs.Remove(tab);
        _contentCache.Remove(tab.Pasta);

        if (_activeTabId == tab.Id)
        {
            _activeTabId = _openTabs.LastOrDefault()?.Id;
            if (_activeTab is not null && _contentCache.TryGetValue(_activeTab.Pasta, out var cached))
            {
                _activeTabContent = cached;
                _lineCount = cached?.Split('\n').Length ?? 0;
            }
            else
            {
                _activeTabContent = null;
                _lineCount = 0;
            }
        }
    }

    private async Task LoadContent(Topic topic)
    {
        if (_contentCache.TryGetValue(topic.Pasta, out var cached))
        {
            _activeTabContent = cached;
        }
        else
        {
            _activeTabContent = topic.TemReadme ? await TopicService.GetReadmeAsync(topic.Pasta) : null;
            _contentCache[topic.Pasta] = _activeTabContent;
        }

        _lineCount = _activeTabContent?.Split('\n').Length ?? 0;
    }

    private bool IsTopicOpen(Topic topic) => _openTabs.Any(t => t.Id == topic.Id);

    private string GetFileIcon(Topic topic) => topic.TemReadme ? "📄" : "📝";

    private string GetTrackFromPath(string pasta)
    {
        var parts = pasta.Split('/');
        return parts.Length >= 2 ? parts[1] : _activeTrackId ?? "";
    }

    private async Task ViewFile(string filePath)
    {
        await OpenFileInRight(filePath);
    }

    private async Task ViewReadme()
    {
        // Not needed anymore with split view
    }

    private async Task OpenFileInRight(string filePath)
    {
        if (_activeTab is null) return;

        if (!_rightTabs.Contains(filePath))
        {
            _rightTabs.Add(filePath);
        }

        _activeRightTab = filePath;
        _rightContent = await TopicService.GetFileAsync(_activeTab.Pasta, filePath);
        _rightLineCount = _rightContent?.Split('\n').Length ?? 0;
        _needsHighlight = true;
    }

    private async Task ActivateRightTab(string filePath)
    {
        if (_activeTab is null) return;
        _activeRightTab = filePath;
        _rightContent = await TopicService.GetFileAsync(_activeTab.Pasta, filePath);
        _rightLineCount = _rightContent?.Split('\n').Length ?? 0;
        _needsHighlight = true;
    }

    private void CloseRightTab(string filePath)
    {
        _rightTabs.Remove(filePath);
        if (_activeRightTab == filePath)
        {
            _activeRightTab = _rightTabs.LastOrDefault();
            if (_activeRightTab is null)
            {
                _rightContent = null;
                _rightLineCount = 0;
            }
        }
    }
}
